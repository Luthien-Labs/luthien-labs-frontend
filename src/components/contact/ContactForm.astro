---
import "./ContactFormStyles.scss";
---

<div id="contact-section">
  <div id="contact-form-container">

    <div id="contact-form-header">
      <p class="contact-eyebrow">Correspondence Protocol</p>
      <h1 id="contact-form-title">Submit an Inquiry</h1>
      <p class="contact-intro">
        Correspondence submitted through this interface is received by the Inquiry
        Processing Unit and forwarded to the appropriate desk within a timeframe
        that is not externally disclosed. The firm welcomes inquiries pertaining
        to ongoing engagements, partnership discussions, and general consultation.
        Inquiries pertaining to events that the firm has formally reclassified
        should be directed through your designated contact. The firm is responsive.
        The firm is always responsive.
      </p>
    </div>

    <div id="contact-form-body">

      <div id="form-success" class="form-message form-success" hidden>
        Your inquiry has been received and assigned a reference number that will
        not be communicated to you. A member of the Correspondence Unit will be in
        contact within a period of time that cannot currently be specified.
      </div>
      <div id="form-error" class="form-message form-error" hidden>
        Transmission unsuccessful. The system has logged this anomaly for internal
        review. Please resubmit, or accept that certain submissions are not subject
        to successful transmission under conditions that have not been disclosed.
      </div>

      <form id="contact-form" data-api-url={import.meta.env.PUBLIC_API_URL} data-api-key={import.meta.env.PUBLIC_API_KEY} novalidate>
        <div class="form-group">
          <label for="name" class="form-label">Name / Designation</label>
          <input type="text" id="name" name="name" class="form-input" placeholder="Full name as registered" required />
        </div>

        <div class="form-group">
          <label for="email" class="form-label">Electronic Return Address</label>
          <input type="email" id="email" name="email" class="form-input" placeholder="you@example.com" required />
        </div>

        <div class="form-group">
          <label for="subject" class="form-label">Matter Classification</label>
          <input type="text" id="subject" name="subject" class="form-input" placeholder="e.g. Partnership enquiry, General consultation, Other" />
        </div>

        <div class="form-group">
          <label for="message" class="form-label">Correspondence Body</label>
          <textarea id="message" name="message" class="form-textarea" placeholder="State your inquiry in full. The Inquiry Processing Unit does not action incomplete submissions." required></textarea>
        </div>

        <!-- Honeypot: hidden from real users, bots fill it in -->
        <div class="hp-field" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <button type="submit" id="submit-button" class="submit-button">Submit Inquiry</button>
      </form>

    </div>
  </div>
</div>

<script is:inline src="/scripts/contact-form.js" type="module"></script>
